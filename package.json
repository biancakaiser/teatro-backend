{
  "name": "backend-teatro",
  "main": "server.js",
  "apidoc": {
    "title": "Documentação de API do teatro",
    "url": "http://localhost:8089/v1"
  },
  "scripts": {
    "start": "cross-env NODE_ENV=dev ./node_modules/.bin/nodemon server.js",
    "test": "./node_modules/.bin/mocha test/main.test.js",
    "docker": "node server.js",
    "launchpad": "cross-env NODE_ENV=launchpad ./node_modules/.bin/pm2 start server.js --name 'teatro' --log-date-format 'YYYY-MM-DD HH:mm:ss.SSS'",
    "prod": "cross-env NODE_ENV=prod ./node_modules/.bin/pm2 start server.js --name 'teatro'  --log-date-format 'YYYY-MM-DD HH:mm:ss.SSS'",
    "pm2": "./node_modules/.bin/pm2",
    "apidoc": "./node_modules/.bin/apidoc -i api/ -o apidoc/",
    "eslint": "./node_modules/.bin/eslint --ignore-path .gitignore ."
  },
  "version": "1.0.1",
  "devDependencies": {
    "apidoc": "^0.17.6",
    "chai": "^4.1.2",
    "cross-env": "^10.1.0",
    "eslint": "^4.19.1",
    "eslint-config-airbnb-base": "^13.0.0",
    "eslint-plugin-import": "^2.13.0",
    "mocha": "^5.2.0",
    "nodemon": "^1.17.5",
    "supertest": "^3.1.0"
  },
  "dependencies": {
    "@google-cloud/storage": "^1.7.0",
    "bcrypt": "^5.1.1",
    "body-parser": "^1.18.3",
    "chance": "^1.0.16",
    "cookie-parser": "^1.4.3",
    "dotenv": "^17.3.1",
    "express": "^4.16.3",
    "express-rate-limit": "^2.11.0",
    "joi": "^13.4.0",
    "knex": "^0.15.0",
    "moment": "^2.22.2",
    "moment-timezone": "^0.5.21",
    "multer": "^1.3.1",
    "mysql": "^2.15.0",
    "mysql2": "^3.19.1",
    "node-mailjet": "^3.2.1",
    "pm2": "^3.0.3",
    "request-promise": "^4.2.2",
    "uuid": "^3.3.2"
  }
}
